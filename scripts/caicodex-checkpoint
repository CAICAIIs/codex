#!/usr/bin/env python3
"""Checkpoint-lite for CAICAI Codex.

Snapshots git working state as binary patches plus untracked file copies. Restore
is explicit and creates a backup checkpoint before destructive changes when
--force is used.
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import shlex
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any


MANIFEST = "manifest.json"
VERSION = 1


class CheckpointError(RuntimeError):
    pass


def now_utc() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat()


def slugify(value: str) -> str:
    slug = "".join(ch.lower() if ch.isalnum() else "-" for ch in value).strip("-")
    while "--" in slug:
        slug = slug.replace("--", "-")
    return slug[:48] or "checkpoint"


def git(args: list[str], cwd: Path, *, input_bytes: bytes | None = None) -> subprocess.CompletedProcess[bytes]:
    return subprocess.run(
        ["git", *args],
        cwd=cwd,
        input=input_bytes,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )


def git_text(args: list[str], cwd: Path, *, check: bool = True) -> str:
    result = git(args, cwd)
    if check and result.returncode != 0:
        raise CheckpointError(result.stderr.decode("utf-8", "replace").strip())
    return result.stdout.decode("utf-8", "replace")


def find_root(start: Path) -> Path:
    result = git(["rev-parse", "--show-toplevel"], start)
    if result.returncode != 0:
        raise CheckpointError("caicodex checkpoint requires a git repository")
    return Path(result.stdout.decode().strip()).resolve()


def target_root(args: argparse.Namespace) -> Path:
    return Path(args.root).expanduser().resolve() if args.root else find_root(Path.cwd())


def checkpoint_base(root: Path) -> Path:
    return root / ".codex" / "checkpoints"


def checkpoint_dir(root: Path, checkpoint_id: str) -> Path:
    return checkpoint_base(root) / checkpoint_id


def relative_checkpoint_prefix(root: Path) -> str:
    try:
        return str(checkpoint_base(root).relative_to(root)).replace(os.sep, "/") + "/"
    except ValueError:
        return ".codex/checkpoints/"


def status_porcelain(root: Path) -> str:
    return git_text(["status", "--porcelain=v1"], root)


def git_head(root: Path) -> str:
    return git_text(["rev-parse", "HEAD"], root).strip()


def untracked_files(root: Path) -> list[str]:
    raw = git(["ls-files", "--others", "--exclude-standard", "-z"], root)
    if raw.returncode != 0:
        raise CheckpointError(raw.stderr.decode("utf-8", "replace").strip())
    prefix = relative_checkpoint_prefix(root)
    paths = []
    for item in raw.stdout.split(b"\0"):
        if not item:
            continue
        rel = item.decode("utf-8", "surrogateescape")
        rel_posix = rel.replace(os.sep, "/")
        if rel_posix.startswith(prefix):
            continue
        paths.append(rel_posix)
    return sorted(paths)


def safe_rel_path(rel: str) -> Path:
    path = Path(rel)
    if path.is_absolute() or ".." in path.parts:
        raise CheckpointError(f"unsafe relative path in checkpoint: {rel}")
    return path


def write_patch(root: Path, args: list[str], path: Path) -> None:
    result = git(args, root)
    if result.returncode != 0:
        raise CheckpointError(result.stderr.decode("utf-8", "replace").strip())
    path.write_bytes(result.stdout)


def copy_untracked(root: Path, destination: Path, paths: list[str]) -> None:
    for rel in paths:
        rel_path = safe_rel_path(rel)
        src = root / rel_path
        if not src.is_file() and not src.is_symlink():
            continue
        dst = destination / rel_path
        dst.parent.mkdir(parents=True, exist_ok=True)
        if src.is_symlink():
            target = os.readlink(src)
            os.symlink(target, dst)
        else:
            shutil.copy2(src, dst)


def allocate_checkpoint_id(root: Path, label: str) -> str:
    stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%d-%H%M%S")
    base = f"{stamp}-{slugify(label)}"
    candidate = base
    counter = 2
    while checkpoint_dir(root, candidate).exists():
        candidate = f"{base}-{counter}"
        counter += 1
    return candidate


def create_checkpoint(args: argparse.Namespace, *, internal_label: str | None = None) -> str:
    root = target_root(args)
    label = internal_label or args.label
    checkpoint_id = allocate_checkpoint_id(root, label)
    dest = checkpoint_dir(root, checkpoint_id)
    dest.mkdir(parents=True, exist_ok=False)

    untracked = untracked_files(root)
    (dest / "untracked").mkdir(parents=True, exist_ok=True)
    copy_untracked(root, dest / "untracked", untracked)
    write_patch(root, ["diff", "--binary", "--cached"], dest / "index.patch")
    write_patch(root, ["diff", "--binary"], dest / "worktree.patch")

    manifest = {
        "version": VERSION,
        "id": checkpoint_id,
        "created_at": now_utc(),
        "root": str(root),
        "label": label,
        "head": git_head(root),
        "status_porcelain": status_porcelain(root),
        "untracked_files": untracked,
        "patches": {
            "index": "index.patch",
            "worktree": "worktree.patch",
            "untracked": "untracked/",
        },
    }
    (dest / MANIFEST).write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    if not getattr(args, "hook", False):
        if getattr(args, "json", False):
            print(json.dumps(manifest, indent=2, sort_keys=True))
        else:
            print(f"checkpoint: {checkpoint_id}")
            print(f"path: {dest}")
    return checkpoint_id


def load_manifest(root: Path, checkpoint_id: str) -> dict[str, Any]:
    path = checkpoint_dir(root, checkpoint_id) / MANIFEST
    if not path.is_file():
        raise CheckpointError(f"checkpoint not found: {checkpoint_id}")
    try:
        manifest = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise CheckpointError(f"invalid checkpoint manifest: {path}: {exc}") from exc
    if manifest.get("version") != VERSION:
        raise CheckpointError(f"unsupported checkpoint version: {manifest.get('version')}")
    return manifest


def list_checkpoints(args: argparse.Namespace) -> None:
    root = target_root(args)
    base = checkpoint_base(root)
    rows = []
    if base.exists():
        for manifest_path in sorted(base.glob(f"*/{MANIFEST}")):
            try:
                rows.append(json.loads(manifest_path.read_text(encoding="utf-8")))
            except json.JSONDecodeError:
                continue
    rows.sort(key=lambda item: item.get("created_at", ""))
    if args.json:
        print(json.dumps(rows, indent=2, sort_keys=True))
        return
    for item in rows:
        print(f"{item.get('id')} {item.get('created_at')} {item.get('label')}")


def show_checkpoint(args: argparse.Namespace) -> None:
    root = target_root(args)
    manifest = load_manifest(root, args.id)
    if args.json:
        print(json.dumps(manifest, indent=2, sort_keys=True))
        return
    print(f"id: {manifest['id']}")
    print(f"created_at: {manifest['created_at']}")
    print(f"label: {manifest['label']}")
    print(f"head: {manifest['head']}")
    print("status:")
    print(manifest.get("status_porcelain", "").rstrip() or "  clean")
    if manifest.get("untracked_files"):
        print("untracked:")
        for path in manifest["untracked_files"]:
            print(f"  {path}")


def require_clean_or_force(root: Path, force: bool) -> None:
    if force:
        return
    status = status_porcelain(root).strip()
    if status:
        raise CheckpointError("working tree is dirty; rerun with --force to create a backup first")


def delete_extra_untracked(root: Path, keep: set[str]) -> None:
    for rel in untracked_files(root):
        if rel in keep:
            continue
        path = root / safe_rel_path(rel)
        if path.is_file() or path.is_symlink():
            path.unlink()


def apply_patch(root: Path, patch_path: Path, args: list[str]) -> None:
    if patch_path.stat().st_size == 0:
        return
    result = git(["apply", "--binary", *args, str(patch_path)], root)
    if result.returncode != 0:
        raise CheckpointError(result.stderr.decode("utf-8", "replace").strip())


def restore_untracked(root: Path, source: Path, paths: list[str]) -> None:
    for rel in paths:
        rel_path = safe_rel_path(rel)
        src = source / rel_path
        dst = root / rel_path
        if dst.exists() or dst.is_symlink():
            if dst.is_dir() and not dst.is_symlink():
                shutil.rmtree(dst)
            else:
                dst.unlink()
        dst.parent.mkdir(parents=True, exist_ok=True)
        if src.is_symlink():
            os.symlink(os.readlink(src), dst)
        elif src.exists():
            shutil.copy2(src, dst)


def restore_checkpoint(args: argparse.Namespace) -> None:
    root = target_root(args)
    manifest = load_manifest(root, args.id)
    current_head = git_head(root)
    if current_head != manifest["head"] and not args.allow_head_mismatch:
        raise CheckpointError(
            "checkpoint HEAD does not match current HEAD; use --allow-head-mismatch only after review"
        )
    require_clean_or_force(root, args.force)

    backup_id = None
    if args.force:
        backup_args = argparse.Namespace(
            root=str(root),
            label=f"pre-restore-{args.id}",
            json=False,
            hook=True,
        )
        backup_id = create_checkpoint(backup_args)

    keep_untracked = set(manifest.get("untracked_files", []))
    if args.delete_extra_untracked:
        delete_extra_untracked(root, keep_untracked)

    result = git(["restore", "--source", "HEAD", "--staged", "--worktree", "--", "."], root)
    if result.returncode != 0:
        raise CheckpointError(result.stderr.decode("utf-8", "replace").strip())

    source_dir = checkpoint_dir(root, args.id)
    apply_patch(root, source_dir / manifest["patches"]["index"], ["--index"])
    apply_patch(root, source_dir / manifest["patches"]["worktree"], [])
    restore_untracked(root, source_dir / "untracked", manifest.get("untracked_files", []))

    print(f"restored checkpoint: {args.id}")
    if backup_id:
        print(f"backup checkpoint: {backup_id}")


def load_hooks(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {"hooks": {}}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise CheckpointError(f"invalid hooks JSON: {path}: {exc}") from exc
    if not isinstance(data, dict):
        raise CheckpointError(f"invalid hooks JSON shape: {path}")
    hooks = data.setdefault("hooks", {})
    if not isinstance(hooks, dict):
        raise CheckpointError(f"invalid hooks map: {path}")
    return data


def install_hook(args: argparse.Namespace) -> None:
    root = target_root(args)
    hooks_path = root / ".codex" / "hooks.json"
    data = load_hooks(hooks_path)
    groups = data.setdefault("hooks", {}).setdefault("UserPromptSubmit", [])
    if not isinstance(groups, list):
        raise CheckpointError("hooks.UserPromptSubmit must be a list")
    script = Path(__file__).resolve()
    command = (
        f"{shlex.quote(str(script))} create --root {shlex.quote(str(root))} "
        "--label user-prompt-submit --hook"
    )
    for group in groups:
        if not isinstance(group, dict):
            continue
        for hook in group.get("hooks", []):
            if isinstance(hook, dict) and hook.get("command") == command:
                print(f"checkpoint hook already installed: {hooks_path}")
                return
    groups.append(
        {
            "hooks": [
                {
                    "type": "command",
                    "command": command,
                    "timeout": 10,
                    "statusMessage": "caicodex checkpoint",
                }
            ]
        }
    )
    hooks_path.parent.mkdir(parents=True, exist_ok=True)
    hooks_path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    print(f"installed checkpoint hook: {hooks_path}")


def status(args: argparse.Namespace) -> None:
    root = target_root(args)
    hooks_path = root / ".codex" / "hooks.json"
    print(f"root: {root}")
    print(f"checkpoint_dir: {checkpoint_base(root)}")
    print(f"hooks: {hooks_path}")
    print(f"working_tree: {'dirty' if status_porcelain(root).strip() else 'clean'}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="CAICAI Codex checkpoint-lite")
    parser.add_argument("--root", help="target git repository root")
    sub = parser.add_subparsers(dest="command", required=True)

    create = sub.add_parser("create", help="create a checkpoint")
    create.add_argument("--label", default="manual")
    create.add_argument("--json", action="store_true")
    create.add_argument("--hook", action="store_true", help=argparse.SUPPRESS)
    create.set_defaults(func=lambda args: create_checkpoint(args))

    list_cmd = sub.add_parser("list", help="list checkpoints")
    list_cmd.add_argument("--json", action="store_true")
    list_cmd.set_defaults(func=list_checkpoints)

    show = sub.add_parser("show", help="show one checkpoint")
    show.add_argument("id")
    show.add_argument("--json", action="store_true")
    show.set_defaults(func=show_checkpoint)

    restore = sub.add_parser("restore", help="restore one checkpoint")
    restore.add_argument("id")
    restore.add_argument("--force", action="store_true", help="backup current state then restore")
    restore.add_argument("--delete-extra-untracked", action="store_true")
    restore.add_argument("--allow-head-mismatch", action="store_true")
    restore.set_defaults(func=restore_checkpoint)

    install = sub.add_parser("install-hook", help="install UserPromptSubmit auto-checkpoint hook")
    install.set_defaults(func=install_hook)

    stat = sub.add_parser("status", help="show checkpoint status")
    stat.set_defaults(func=status)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
        return 0
    except CheckpointError as exc:
        print(f"caicodex-checkpoint: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
